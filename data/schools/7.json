          {
            "name": "桃源乡",
            "description": "山海经的学生们常常用来作为咖啡馆替代品的古风茶馆。对于山海经的学生来说，喝茶与枪战一样理所当然。",
            "x": 0.6812008577555396,
            "y": 0.46756152125279643
          },
          {
            "name": "玄武商会",
            "description": "在山海经以外也是知名美食地点，商会成员在繁华街巷从事商业活动。主要销售使用大量香料制作而成的中餐，并且还提供各种珍藏商品。",
            "x": 0.4024303073624017,
            "y": 0.34116331096196867
          },
          {
            "name": "梅花园主楼",
            "description": "山海经的学生们接受教育的梅花园主楼。由于山海经注重教育，即使是玄龙门的干部也不能随意干涉梅花园的事务。",
            "x": 0.315939957112223,
            "y": 0.6510067114093959
          },
          {
            "name": "炼丹术研究所",
            "description": "炼丹术研究会的成员们打磨自己的炼丹术的陈旧研究所。每次路过建筑前都会有刺鼻和异常气味，因此很多学生不愿靠近。",
            "x": 0.47248034310221587,
            "y": 0.8590604026845637
          },
          {
            "name": "茶园",
            "description": "一片广阔的茶田，可以收获山海经特产的茶叶。在这里收获的茶叶被销售到圣三一综合学院和基沃托斯的各个地区。",
            "x": 0.07505360972122944,
            "y": 0.46196868008948544
          },
          {
            "name": "竹林",
            "description": "一片密集在昆仑山入口处的竹林。由于容易迷路，大部分学生都不会进入其中，但似乎有些学生会来此倾诉难以启齿的秘密或者平复心灵纷乱。",
            "x": 0.7455325232308792,
            "y": 0.7449664429530202
          }
