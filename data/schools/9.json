        "mark": [
          {
            "name": "百鬼夜行阴阳部本馆",
            "description": "百鬼夜行联合学院实质上的学生会·阴阳部所在的主楼。据说，在学生们之间流传着各种陷阱和防御设施都已经准备好了。",
            "x": 0.41887062187276625,
            "y": 0.1890380313199105
          },
          {
            "name": "中央广场",
            "description": "从阴阳部本馆可以看到的巨大广场。作为游客集合的地方被利用，中央广场上的铜像也以拍照点而受欢迎。",
            "x": 0.47962830593280914,
            "y": 0.4597315436241611
          },
          {
            "name": "阴阳部公演会场",
            "description": "不定期举办阴阳部演出活动的会场。俳句对战、尼娅的落语大会、千世展示特技等——每次演出都因门票售罄而闻名。",
            "x": 0.5475339528234453,
            "y": 0.3624161073825503
          },
          {
            "name": "大庭园",
            "description": "著名景点，必定要参观一下才算来过百鬼夜行。百鬼夜行游客的常去之处。尤其是有传言称池塘里住着被称为“主”的巨型锦鲤。周边还有商品销售。",
            "x": 0.3516797712651894,
            "y": 0.6677852348993288
          },
          {
            "name": "百鬼夜行商店街",
            "description": "百鬼夜行联合学院的商店街。著名喫茶店“百夜堂”也位于此处。据说当问题孩子引起混乱时，百夜堂的招牌女孩会出马解决。",
            "x": 0.6132952108649035,
            "y": 0.6532438478747203
          },
          {
            "name": "观光用缆车",
            "description": "百鬼夜行联合学院的缆车。据说从车上俯瞰百鬼夜行全景会成为难以忘怀的回忆。往返费用为500円。",
            "x": 0.3002144388849178,
            "y": 0.5425055928411633
          },
          {
            "name": "传统博物馆",
            "description": "可以体验到百鬼夜行联合学院独特传统和历史的巨大博物馆。据访问过的学生评价并不是很好。",
            "x": 0.6561829878484632,
            "y": 0.3131991051454139
          },
          {
            "name": "神木展望台",
            "description": "可以一览百鬼夜行全景的展望台。由于其壮丽景色，已经成为众多电影和剧集取景地，因此而闻名作圣地。",
            "x": 0.24731951393852752,
            "y": 0.37472035794183445
          }
        ]
      }
